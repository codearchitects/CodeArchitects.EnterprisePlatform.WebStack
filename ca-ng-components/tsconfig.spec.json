{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "jasmine",
      "node",
      "reflect-metadata"
    ],
    "typeRoots": [
      "../node_modules/@types",
      "../node_modules"
    ],
    "module": "commonjs",
    "preserveSymlinks": true,
    "skipLibCheck": true
  },
  "files": [
    "./src/test.ts"
  ],
  "include": [
    "./src/**/*.spec.ts",
    "./src/**/*.d.ts"
  ],
  "exclude": [
    "./src/tests/fixtures"
  ]
}