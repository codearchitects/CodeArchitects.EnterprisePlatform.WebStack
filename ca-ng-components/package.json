    "ngx-mydatepicker": "^2.4.9",
    "ngx-numeral": "^0.0.1-beta.0",
    "numeral": "^2.0.6",
    "vm": "^0.1.0"
  },
  "devDependencies": {
    "sass": "^1.32.0",
    "@angular-devkit/build-angular": "~0.801.2",
    "@angular/animations": "^8.1.2",
    "@angular/cdk": "^7.2.3",
    "@angular/cli": "^8.1.2",
    "@angular/common": "^8.1.2",
    "@angular/compiler": "^8.1.2",
    "@angular/compiler-cli": "^8.1.2",
    "@angular/core": "^8.1.2",
    "@angular/forms": "^8.1.2",
    "@angular/http": "^7.2.3",
    "@angular/language-service": "^8.1.2",
    "@angular/platform-browser": "^8.1.2",
    "@angular/platform-browser-dynamic": "^8.1.2",
    "@angular/router": "^8.1.2",
    "@ca-webstack/data-structures": "*",
    "@ca-webstack/ng-aspects": "*",
    "@ca-webstack/ng-command-dispatcher": "*",
    "@ca-webstack/ng-i18n": "*",
    "@ca-webstack/ng-policy-engine": "*",
    "@ca-webstack/policy-engine": "*",
    "@ca-webstack/reflection": "*",
    "@ngx-translate/core": "^11.0.1",
    "@ngx-translate/http-loader": "^4.0.0",
    "@types/core-js": "^2.5.0",
    "@types/jasmine": "^3.3.8",
    "@types/jasminewd2": "^2.0.6",
    "@types/jquery": "^3.3.29",
    "@types/lodash": "4.14.120",
    "@types/node": "^10.12.21",
    "@types/numeral": "^0.0.25",
    "angular2-toaster": "^7.0.0",
    "codelyzer": "^5.0.1",
    "core-js": "^2.6.3",
    "jasmine-core": "^3.3.0",
    "jasmine-spec-reporter": "^4.2.1",
    "jquery": "^3.3.1",
    "karma": "^4.0.0",
    "karma-chrome-launcher": "^2.2.0",
    "karma-coverage-istanbul-reporter": "^2.0.4",
    "karma-jasmine": "^2.0.1",
    "karma-jasmine-html-reporter": "^1.4.0",
    "ng-packagr": "^5.7.1",
    "lodash": "^4.17.11",
    "ngx-contextmenu": "^5.1.1",
    "protractor": "^5.4.2",
    "rxjs": "^6.4.0",
    "ts-node": "^8.0.2",
    "tslint": "^5.12.1",
    "typescript": "3.4.5",
    "zone.js": "^0.11.3"
  },
  "scripts": {
    "clean": "npm run clean.artifacts && npm run clean.node_modules",
    "clean.artifacts": "node rimraf.js dist .tmp typedocs",
    "clean.node_modules": "node rimraf.js node_modules && rm -f package-lock.json",
    "setup": "npm install --no-optional --loglevel=error",
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "test": "npm run test.unit",
    "test.unit": "ng test --watch=false --code-coverage",
    "test.unit.watch": "ng test",
    "test.integration": "cd tests/integration && npm run test",
    "test.dev": "npm run test && start ./coverage/index.html",
    "demo": "cd demo && npm run start",
    "typedoc": "npm run clean.artifacts && typedoc --out typedocs public_api.ts --module commonjs --target es6 --theme minimal --exclude node_modules --readme none"
  },
  "config": {
    "ca": {
      "rollupOptions": {
        "entryPoint": "public_api.ts",
        "tsconfig": "tsconfig.json",
        "externals": [
          "lodash",
          "numeral",
          "numeral/locales",
          "ngx-translate",
          "rxjs",
          "rxjs/operators",
          "typescript"
        ],
        "copy": [
          {
            "from": "src/styles",
            "to": "."
          }
        ],
        "targets": {
          "angular": true,
          "web": false,
          "node": false
        }
      }
    }
  },
  "main": "dist/bundles/ca-webstack-ng-components.umd.js",
  "module": "dist/fesm5/ca-webstack-ng-components.js",
  "typings": "dist/ca-webstack-ng-components.d.ts"
}
