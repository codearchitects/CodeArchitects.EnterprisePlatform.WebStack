    "@angular/animations": "^8.1.2",
    "@angular/compiler": "^8.1.2",
    "@angular/forms": "^8.1.2",
    "@angular/http": "^7.2.3",
    "@ca-webstack/policy-engine": "*",
    "@ca-webstack/reflection": "*",
    "rxjs": "^6.4.0",
    "zone.js": "~0.9.1"
  },
  "dependencies": {
    "core-js": "^2.6.3",
    "tslib": "^1.9.3"
  },
  "devDependencies": {
    "@angular/cli": "^8.1.2",
    "@angular/animations": "^8.1.2",
    "@angular/common": "^8.1.2",
    "@angular/compiler": "^8.1.2",
    "@angular/compiler-cli": "^8.1.2",
    "@angular-devkit/build-angular": "~0.801.2",
    "@angular/core": "^8.1.2",
    "@angular/forms": "^8.1.2",
    "@angular/http": "^7.2.3",
    "@angular/platform-browser": "^8.1.2",
    "@angular/platform-browser-dynamic": "^8.1.2",
    "@angular/router": "^8.1.2",
    "@ca-webstack/policy-engine": "*",
    "@ca-webstack/reflection": "*",
    "@types/chai": "~4.0.0",
    "@types/core-js": "^2.5.0",
    "@types/jasmine": "^3.3.8",
    "@types/mocha": "~2.2.41",
    "@types/node": "^10.12.21",
    "@types/proxyquire": "^1.3.28",
    "@types/sinon": "^4.0.0",
    "@types/sinon-chai": "^2.7.29",
    "codelyzer": "^5.0.1",
    "cpr": "^3.0.1",
    "jasmine": "^2.8.0",
    "jasmine-core": "~2.99.1",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "~1.7.1",
    "karma-chrome-launcher": "~2.2.0",
    "karma-coverage-istanbul-reporter": "~2.0.0",
    "karma-jasmine": "~1.1.1",
    "karma-jasmine-html-reporter": "^0.2.2",
    "ng-packagr": "^5.7.1",
    "karma-spec-reporter": "0.0.31",
    "minimist": "^1.2.0",
    "mocha": "~3.4.2",
    "nyc": "^13.1.0",
    "protractor": "~5.3.0",
    "rimraf": "^2.6.3",
    "rxjs": "^6.4.0",
    "ts-node": "^8.0.2",
    "tslint": "^5.12.1",
    "typedoc": "^0.14.2",
    "typemoq": "^2.1.0",
    "typescript": "3.4.5",
    "zone.js": "~0.9.1"
  },
  "scripts": {
    "clean": "npm run clean.artifacts && npm run clean.node_modules",
    "clean.artifacts": "node rimraf.js dist .tmp typedocs",
    "clean.node_modules": "node rimraf.js node_modules",
    "setup": "npm install --no-optional --loglevel=error",
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "test": "npm run test.unit",
    "test.unit": "ng test --watch=false",
    "test.integration": "cd tests/integration && npm run test",
    "test.watch": "ng test",
    "e2e": "cd tests/integration && npm run e2e",
    "demo": "cd demo && npm run start",
    "typedoc": "npm run clean.artifacts && typedoc --out typedocs public_api.ts --module commonjs --target es6 --theme minimal --exclude node_modules --readme none"
  },
  "config": {
    "ca": {
      "rollupOptions": {
        "entryPoint": "public_api.ts",
        "tsconfig": "tsconfig.app.json",
        "externals": [
          "rxjs/",
          "rxjs/operators",
          "jasmine"
        ],
        "targets": {
          "angular": true,
          "web": false,
          "node": false
        }
      }
    }
  },
  "main": "dist/bundles/ca-webstack-ng-policy-engine.umd.js",
  "module": "dist/fesm5/ca-webstack-ng-policy-engine.js",
  "typings": "dist/ca-webstack-ng-policy-engine.d.ts"
}
