{
  "extends": "./tsconfig.json",
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": [
    "tests/integration/test.ts",
    "tests/integration/src/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    ".tmp",
    "dist",
    "tests/integration/node_modules",
    "tests/integration/e2e",
    "node_modules",
    "demo"
  ]
}
