{
  "name": "caep-snippets",
  "displayName": "CAEP Snippets",
  "description": "CAEP Snippets is a Visual Studio Code extension that enhances your coding experience with typescript and HTML snippets.",
  "version": "0.0.1",
  "private": "true",
  "repository": {},
  "engines": {
    "vscode": "^1.75.0"
  },
  "scripts": {
    "pack": "vsce package  --out packages",
    "install-snippet": "code --install-extension ./packages/caep-snippets-%npm_package_version%.vsix",
    "install-snippet:bash": "code --install-extension ./packages/caep-snippets-$npm_package_version.vsix"
  },
  "categories": [
    "Snippets"
  ],
  "contributes": {
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/typescript.json"
      },
      {
        "language": "html",
        "path": "./snippets/html.json"
      },
      {
        "language": "yaml",
        "path": "./snippets/yaml.json"
      },
      {
        "language": "scss",
        "path": "./snippets/scss.json"
      },
      {
        "language": "html",
        "path": "./snippets/old-html.json"
      }
    ]
  },
  "devDependencies": {
    "vsce": "^2.15.0"
  }
}