{
  "name": "@ca-webstack/ng-components-extra",
  "private": false,
  "version": "0.0.0",
  "ngPackageExports": {
    ".": {
      "sass": "./styles/index.scss"
    }
  },
  "scripts": {
    "prebuild": "npm run clean.artifacts",
    "build": "ng build",
    "postbuild": "node ../scripts/merge-pkg-exports.mjs",
    "i": "npm run setup",
    "setup": "npm install --loglevel=error",
    "test": "npm run test.unit",
    "test-integration": "ng build && ng serve integration --port=3232",
    "test.unit": "ng test --watch=false --code-coverage --project=ng-components",
    "test.unit.watch": "ng test --watch --project=ng-components",
    "watch": "ng build  --watch --configuration development",
    "clean": "npm run clean.packages && npm run clean.artifacts",
    "clean.packages": "rm -rf ./node_modules && rm -f package-lock.json",
    "clean.artifacts": "rm -rf ./dist"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.0",
    "@angular/animations": "~21.2.0",
    "@angular/cdk": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/platform-browser-dynamic": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@ca-webstack/data-structures": "*",
    "@ca-webstack/ng-aspects": "*",
    "@ca-webstack/ng-i18n": "*",
    "@ca-webstack/ng-policy-engine": "*",
    "@ca-webstack/ng-shell": "*",
    "@ca-webstack/policy-engine": "*",
    "@ca-webstack/reflection": "*",
    "@ngx-translate/core": "^15.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/jquery": "^3.3.29",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.3",
    "@types/numeral": "^0.0.25",
    "angular2-uuid": "^1.1.1",
    "core-js": "^3.41.0",
    "jasmine-core": "~5.13.0",
    "jquery": "^3.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "lodash-es": "^4.17.23",
    "ng-packagr": "~21.2.0",
    "numeral": "^2.0.6",
    "rxjs": "~7.8.1",
    "typescript": "5.9.3",
    "zone.js": "~0.16.0"
  },
  "peerDependencies": {
    "@angular/common": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@ca-webstack/data-structures": "*",
    "@ca-webstack/ng-aspects": "*",
    "@ca-webstack/ng-i18n": "*",
    "@ca-webstack/ng-policy-engine": "*",
    "@ca-webstack/ng-shell": "*",
    "@ca-webstack/policy-engine": "*",
    "@ca-webstack/reflection": "*",
    "@ngx-translate/core": "^15.0.0",
    "angular2-uuid": "^1.1.1",
    "core-js": "^3.41.0",
    "jquery": "^3.6.0",
    "lodash-es": "^4.17.23",
    "numeral": "^2.0.6",
    "rxjs": "~7.8.1"
  },
  "module": "dist/ng-components/fesm2022/ca-webstack-ng-components-extra.mjs",
  "typings": "dist/ng-components/types/ca-webstack-ng-components-extra.d.ts"
}
