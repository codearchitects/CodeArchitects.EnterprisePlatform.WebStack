{
  "name": "@ca-webstack/data-context",
  "version": "21.0.0",
  "description": "Data context utilities.",
  "author": "Code Architects S.r.l. (https://www.codearchitects.com/)",
  "license": "Apache-2.0",
  "typings": "dist/types/public_api.d.ts",
  "peerDependencies": {
    "@ca-webstack/change-tracker": "21.0.0",
    "@ca-webstack/data-structures": "21.0.0",
    "@ca-webstack/reflection": "21.0.0",
    "core-js": "^3.41.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@ca-webstack/change-tracker": "21.0.0",
    "@ca-webstack/data-structures": "21.0.0",
    "@ca-webstack/reflection": "21.0.0",
    "@types/core-js": "^2.5.8",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.19.3",
    "@types/proxyquire": "^1.3.28",
    "core-js": "^3.41.0",
    "cpr": "^3.0.1",
    "generate-package-json-webpack-plugin": "^2.6.0",
    "jest": "^29.7.0",
    "lodash": "^4.17.21",
    "proxyquire": "^2.1.0",
    "rimraf": "^2.6.3",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.0.0",
    "tslib": "^2.3.0",
    "tslint": "^5.12.1",
    "ts-jest": "^29.2.2",
    "typedoc": "^0.28.15",
    "typescript": "5.9.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "scripts": {
    "clean": "npm run clean.artifacts && npm run clean.node_modules",
    "clean.artifacts": "node rimraf.js dist .tmp typedocs",
    "clean.node_modules": "node rimraf.js node_modules",
    "setup": "npm install --no-optional --loglevel=error",
    "restore": "npm run clean && npm run setup",
    "prebuild": "npm run clean.artifacts",
    "build": "webpack --mode production",
    "build.test": "npm run clean.artifacts && tsc -p tsconfig.tests.json --outDir .tmp",
    "test": "npm run test.unit",
    "test.unit": "jest",
    "test.unit.watch": "jest --watch",
    "test.unit.coverage": "jest --coverage",
    "typedoc": "npm run clean.artifacts && typedoc public_api.ts --out typedocs --theme default --exclude node_modules --readme none"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.(test|spec).ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "./setup.jest.ts"
    ],
    "modulePaths": [
      "<rootDir>"
    ],
    "moduleDirectories": [
      "node_modules",
      "dist",
      "src"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/integration/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/build/",
      "/coverage/",
      "/.tmp/",
      "/.vscode/",
      "/docs/",
      "index.ts",
      "public_api.ts",
      "rimraf.js",
      "webpack.config.js",
      "/tests/integration/"
    ]
  },
  "main": "dist/bundles/@ca-webstack/data-context.umd.js",
  "types": "dist/types/public_api.d.ts"
}
