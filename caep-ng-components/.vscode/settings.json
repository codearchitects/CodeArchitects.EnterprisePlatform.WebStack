{
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    },
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    }
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "angular.log": "verbose",
  "workbench.colorCustomizations": {
    "statusBar.background": "#576574",
    "statusBar.foreground": "#ebeef2",
    "statusBarItem.remoteBackground": "#576574",
    "statusBarItem.remoteForeground": "#ebeef2",
    "badge.background": "#576574",
    "badge.foreground": "#ebeef2",
    "activityBar.background": "#576574",
    "activityBar.inactiveForeground": "#ebeef2",
    "activityBar.activeBackground": "#222f3e",
    "activityBarBadge.background": "#576574",
    "activityBarBadge.foreground": "#ebeef2",
    "activityBar.activeBorder": "#576574",
    "window.activeBorder": "#576574",
    "window.inactiveBorder": "#576574",
    "titleBar.activeBackground": "#576574",
    "titleBar.activeForeground": "#ebeef2",
    "titleBar.inactiveBackground": "#576574",
    "titleBar.inactiveForeground": "#ebeef2"
  },
  "window.title": "CAEP: NgComponents",
  "[html][scss][typescript]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  }
}