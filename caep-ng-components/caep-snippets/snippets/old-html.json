        "scope": "html",
        "prefix": "input-group-h",
        "body": [
            "<div input-group-h>",
            "$1",
            "</div>$0"
        ]
    },
    "ca-input-group-v": {
        "scope": "html",
        "prefix": "input-group-v",
        "body": [
            "<div input-group-v>",
