    "ca-input-checkbox": {
        "scope": "html",
        "prefix": "sh-checkbox",
        "body": "<sh-checkbox [model]=\"$1\" prop=\"$2\"></sh-checkbox>$0",
        "description": "Elements of type checkbox are rendered by default as square boxes that are checked when activated, like you might see in an official government paper form."
    },
    "ca-input-checkgroup": {
        "scope": "html",
        "prefix": "sh-checkgroup",
        "body": "<sh-checkgroup [model]=\"$1\" prop=\"$2\" [options]=\"$4\"></sh-checkgroup>$0"
    },
    "ca-input-combo": {
        "scope": "html",
        "prefix": "sh-combo",
        "body": "<sh-combo [model]=\"$1\" prop=\"$2\" [options]=\"$3\"></sh-combo>$0"
    },
    "ca-input-date": {
        "scope": "html",
        "prefix": "sh-date",
        "body": "<sh-date [model]=\"$1\" prop=\"$2\"></sh-date>$0"
    },
