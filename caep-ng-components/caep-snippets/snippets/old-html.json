{
    "ca-value-changes": {
        "prefix": "valueChanges",
        "body": "(valueChanges)=\"$1(\\$event)\"$0"
    },
    "ca-button": {
        "scope": "html",
        "prefix": [
            "sh-button",
            "ca-button"
        ],
        "body": "<sh-button (clicked)=\"$0\" [primary]=\"true\">$1</sh-button>",
        "description": "The Button is an Angular directive which detects user interaction and triggers a corresponding event."
    },
    "ca-button-group": {
        "scope": "html",
        "prefix": "sh-button-group",
        "body": [
            "<div button-group>",
            "  <sh-button (clicked)=\"$1\">cancel</sh-button>",
            "  <sh-button (clicked)=\"$2\" [primary]=\"true\">confirm</sh-button>",
            "</div>"
        ],
        "description": "The Button Group is an attribute applied to a container that have to contains two or more Button components."
    },
    "ca-captions": {
        "scope": "html",
        "prefix": "sh-caption",
        "body": " <sh-caption [model]=\"$1\" prop=\"$2\"></sh-caption>$0",
        "description": "The Caption defines a simple label that does not render anything special for the user. It supports internationalization by design."
    },
    "ca-card": {
        "scope": "html",
        "prefix": "sh-card",
        "body": [
            "<sh-card title=\"$1\" [hasConfirmButton]=\"true\" [hasCancelButton]=\"true\" [model]=\"person\" (confirm)=\"$2\" (cancel)=\"$3\">",
            "$2",
            "</sh-card>$0"
        ],
        "description": "A card provides a flexible and extensible content container with multiple variants and options"
    },
    "ca-enable": {
        "scope": "html",
        "prefix": "enable",
        "body": "[enable]=\"$1\"$0",
        "description": "Specifies if the control is enabled"
    },
    "ca-icon": {
        "scope": "html",
        "prefix": "sh-icon",
        "body": "<sh-icon name=\"${1:no-icon}\"></sh-icon>$0",
        "description": "Framework offers a series of built-in icons ready to be used, which represent delicious symbols created for common actions and objects."
    },
    "ca-input": {
        "scope": "html",
        "prefix": [
            "sh-",
            "ca-"
