        "body": "<sh-${1|form-control,checkbox,checkgroup,combo,date,multiselect,radio,select,text,textarea|} [model]=\"${2|model,this|}\" prop=\"${3}\" [options]=\"${3}Options\"></sh-${1}>$0"
    },
