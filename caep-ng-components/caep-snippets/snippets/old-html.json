        "scope": "html",
        "prefix": "sh-multiselect",
        "body": "<sh-multiselect [model]=\"$1\" prop=\"$2\" [options]=\"$3\"></sh-multiselect>$0"
    },
    "ca-input-radio": {
        "scope": "html",
        "prefix": "sh-radio",
        "body": "<sh-radio [model]=\"$1\" prop=\"$2\" [options]=\"$3\"></sh-radio>$0"
    },
    "ca-input-select ": {
        "scope": "html",
        "prefix": "sh-select ",
        "body": "<sh-select [model]=\"$1\" prop=\"$2\" [options]=\"$3\"></sh-select>$0"
    },
    "ca-input-text": {
        "scope": "html",
        "prefix": "sh-text",
        "body": "<sh-text [model]=\"$1\" prop=\"$2\" [options]=\"{placeholder: 'standard-input'}\"></sh-text>$0",
        "description": "The Inputs are fields which allow for an input of data, based on a specific and predefined format"
    },
    "ca-input-textarea": {
        "scope": "html",
        "prefix": "sh-textarea",
        "body": "<sh-textarea [model]=\"$1\" prop=\"$2\" [options]=\"{placeholder: 'standard-textarea'}\"></sh-textarea>$0",
        "description": "The TextArea enables you to style and provide a floating label functionality to textarea elements"
    },
    "ca-modal": {
        "scope": "html",
        "prefix": "sh-modal",
        "body": [
            "<sh-modal *ngIf=\"$1\" [(model)]=\"$1\" title=\"modal-close-management\"",
            "   [closeOnConfirm]=\"false\" [closeOnClickOutside]=\"true\" [hasCancelButton]=\"false\" confirmText=\"confirm\"",
            "   (confirm)=\"${2:isConfirmed = !isConfirmed}\">",
            "   <div body>",
            "     $0",
            "   </div>",
            "</sh-modal>"
        ]
    },
    "ca-options": {
        "scope": "html",
        "prefix": "options",
        "body": "[options]=\"$1\"$0",
        "description": "See properties section for options details"
    },
    "ca-row": {
        "scope": "html",
        "prefix": "row",
        "description": "Thanks to the \"Grid-System\" it is possible to use a powerful mobile-first flexbox grid to create layouts of all shapes and sizes thanks to a twelve-column system, five predefined responsive breakpoints, SCSS variables and mixins and dozens of predefined classes.",
        "body": [
            "<row>",
            "  <column [xs]=\"12\" [sm]=\"8\" [md]=\"6\" [lg]=\"4\" [xl]=\"6\">",
            "$0",
            "  </column>",
            "</row>"
        ]
    },
    "ca-show": {
        "scope": "html",
        "prefix": "show",
        "body": "[show]=\"$1\"$0",
        "description": "Specifies if the control is visible"
    },
    "ca-spinner": {
        "scope": "html",
        "prefix": "sh-spinner",
        "body": "<sh-spinner *ngIf=\"isLoading\" [isOverlay]=\"true\"></sh-spinner>",
        "description": "Object used like loader"
    },
    "ca-tabs": {
        "scope": "html",
        "prefix": "sh-tabs",
        "body": [
            "<sh-tabs toolbar [model]=\"$1\" (tabChange)=\"${2:currentTab = $\\$event}\"></sh-tabs>",
            "<ng-container *ngIf=\"currentTab\">",
            "  <ng-container [ngSwitch]=\"currentTab.id\">",
            "    <ng-container *ngSwitchCase=\"0\">",
            "",
            "    </ng-container>",
            "    <ng-container *ngSwitchCase=\"1\">",
            "",
            "    </ng-container>",
            "  </ng-container>",
            "</ng-container>",
            "$0"
        ]
    }
}