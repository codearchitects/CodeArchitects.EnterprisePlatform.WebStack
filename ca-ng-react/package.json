  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codearchitects/CodeArchitects.EnterprisePlatform.WebStack.git"
  },
  "peerDependencies": {
    "@angular/core": "^8.1.2",
    "@angular/router": "^8.1.2",
    "@angular/platform-browser": "^8.1.2",
    "@angular/common": "^8.1.2",
    "@angular/platform-browser-dynamic": "^8.1.2",
    "@angular/animations": "^8.1.2",
    "@angular/compiler": "^8.1.2",
    "@angular/forms": "^8.1.2",
    "@angular/http": "^7.2.3",
    "@ca-webstack/ng-components": "*",
    "core-js": "^2.6.3",
    "rxjs": "^6.4.0",
    "zone.js": "~0.9.1"
  },
  "dependencies": {
    "react": "^16.7.0",
    "react-dom": "^16.7.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.801.2",
    "@angular/animations": "^8.1.2",
    "@angular/cdk": "^7.2.3",
    "@angular/cli": "^8.1.2",
    "@angular/common": "^8.1.2",
    "@angular/compiler": "^8.1.2",
    "@angular/compiler-cli": "^8.1.2",
    "@angular/core": "^8.1.2",
    "@angular/forms": "^8.1.2",
    "@angular/http": "^7.2.3",
    "@angular/language-service": "^8.1.2",
    "@angular/platform-browser": "^8.1.2",
    "@angular/platform-browser-dynamic": "^8.1.2",
    "@angular/router": "^8.1.2",
    "@ca-webstack/ng-components": "*",
    "@types/core-js": "^2.5.0",
    "@types/jasmine": "^3.3.8",
    "@types/jasminewd2": "^2.0.6",
    "@types/react": "^16.7.20",
    "@types/react-dom": "^16.0.11",
    "@types/minimatch": "^2.0.29",
    "@types/node": "^10.12.21",
    "codelyzer": "^5.0.1",
    "core-js": "^2.6.3",
    "jasmine-core": "^3.3.0",
    "jasmine-spec-reporter": "^4.2.1",
    "karma": "^4.0.0",
    "karma-chrome-launcher": "^2.2.0",
    "karma-coverage-istanbul-reporter": "^2.0.4",
    "karma-jasmine": "^2.0.1",
    "karma-jasmine-html-reporter": "^1.4.0",
    "ng-packagr": "^5.7.1",
    "protractor": "^5.4.2",
    "rxjs": "^6.4.0",
    "ts-node": "^8.0.2",
    "tslint": "^5.12.1",
    "typescript": "3.4.5"
  },
  "scripts": {
    "clean": "npm run clean.artifacts && npm run clean.node_modules",
    "clean.artifacts": "node rimraf.js dist .tmp typedocs",
    "clean.node_modules": "node rimraf.js node_modules",
    "setup": "npm install --no-optional --loglevel=error",
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "test": "npm run test.unit",
    "test.unit": "npm run build",
    "test.integration": "node -e \"console.log('No integration test project found in tests/integration; skipping.');\"",
    "test.watch": "ng test --unit --reporters=spec,coverage-istanbul,kjhtml --progress=false",
    "e2e": "cd tests/integration && npm run e2e",
    "demo": "cd demo && npm run start",
    "typedoc": "npm run clean.artifacts && typedoc --out typedocs public_api.ts --module commonjs --target es6 --theme minimal --exclude node_modules --readme none"
  },
  "config": {
    "ca": {
      "rollupOptions": {
        "entryPoint": "public_api.ts",
        "tsconfig": "tsconfig.json",
        "externals": [],
        "targets": {
          "angular": true,
          "web": false,
          "node": false
        }
      }
    }
  },
  "main": "dist/bundles/ca-webstack-ng-react.umd.js",
  "module": "dist/fesm5/ca-webstack-ng-react.js",
  "typings": "dist/ca-webstack-ng-react.d.ts"
}