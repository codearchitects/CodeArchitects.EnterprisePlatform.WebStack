    "setup": "npm install --loglevel=error",
    "build": "ng build",
    "test": "npm run test.unit",
    "test.unit": "ng test --watch=false",
    "test.watch": "ng test --reporters=spec,coverage-istanbul,kjhtml --progress=false",
