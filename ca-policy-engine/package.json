{
  "name": "@ca-webstack/policy-engine",
  "version": "0.0.0",
  "description": "Policy engine core library",
  "author": "Code Architects S.r.l. (https://www.codearchitects.com/)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codearchitects/CodeArchitects.EnterprisePlatform.WebStack.git"
  },
  "dependencies": {
    "core-js": "^2.6.3",
    "tslib": "^1.9.3"
  },
  "peerDependencies": {
    "rxjs": "^6.4.0"
  },
  "devDependencies": {
    "@types/chai": "^4.1.7",
    "@types/core-js": "^2.5.0",
    "@types/mocha": "^5.2.5",
    "@types/node": "^10.12.18",
    "@types/proxyquire": "^1.3.28",
    "@types/sinon": "^7.0.5",
    "@types/sinon-chai": "^3.2.2",
    "chai": "^4.2.0",
    "cpr": "^3.0.1",
    "mocha": "^5.2.0",
    "nyc": "^15.0.0",
    "proxyquire": "^2.1.0",
    "rimraf": "^2.6.3",
    "rxjs": "^6.4.0",
    "sinon": "^7.2.3",
    "sinon-chai": "^3.3.0",
    "ts-node": "^8.0.2",
    "tslint": "^5.12.1",
    "typedoc": "^0.14.2",
    "typescript": "3.4.5"
  },
  "scripts": {
    "clean": "npm run clean.artifacts && npm run clean.node_modules",
    "clean.artifacts": "node rimraf.js dist .tmp typedocs",
    "clean.node_modules": "node rimraf.js node_modules",
    "setup": "npm install --no-optional --loglevel=error",
    "build": "npm run clean.artifacts && tsc -p tsconfig.build.json && node scripts/create-dist-package.js",
    "build.test": "npm run clean.artifacts && tsc -p tsconfig.tests.json --outDir .tmp",
    "test": "npm run test.unit",
    "test.unit": "nyc -e .ts -x bin -x src/**/*.spec.ts -x tests mocha -r ts-node/register src/**/*.spec.ts",
    "test.integration": "cd tests/integration && npm run test",
    "typedoc": "npm run clean.artifacts && typedoc --out typedocs public_api.ts --module commonjs --target es6 --theme minimal --exclude node_modules --readme none"
  },
  "config": {
    "ca": {
      "rollupOptions": {
        "entryPoint": "public_api.ts",
        "tsconfig": "tsconfig.json",
        "externals": [
          "rxjs/",
          "rxjs/operators",
          "typescript"
        ],
        "targets": {
          "angular": false,
          "web": true,
          "node": true
        }
      }
    }
  },
  "main": "dist/types/public_api.js",
  "typings": "dist/types/public_api.d.ts"
}
