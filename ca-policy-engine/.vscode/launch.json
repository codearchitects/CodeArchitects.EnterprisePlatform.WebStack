{
  "version": "0.2.0",
  "configurations": [{
    "type": "node",
    "request": "launch",
    "name": "Debug tests",
    "cwd": "${workspaceRoot}",
    "preLaunchTask": "build.test",
    "program": "${workspaceRoot}/node_modules/mocha/bin/_mocha",
    "args": [
      "-u",
      "tdd",
      "--timeout",
      "999999",
      "--colors",
      ".tmp/**/*.spec.js"
    ],
    "sourceMaps": true,
    "outFiles": [".tmp/**/*.js"],
    "internalConsoleOptions": "openOnSessionStart"
  }]
}
