{
  "name": "@ca-webstack/vb6-library",
  "version": "0.0.0",
  "description": "VB6 Typescript Library",
  "scripts": {
    "setup": "npm install --no-optional --loglevel=error && cp .npmrc ./tests/integration/fixtures/.npmrc",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/create-dist-package.js",
    "prestart": "npm run build",
    "test": "npm run test.unit",
    "test.unit": "cross-env NODE_ICU_DATA=node_modules/full-icu jest",
    "test.integration": "npm run build && cd tests/integration/fixtures && npm run setup && npm run test",
    "test.coverage": "npm run test -- --coverage",
    "test.watch": "npm run test -- --watch"
  },
  "author": "Code Architects S.r.l. (https://www.codearchitects.com/)",
  "license": "Apache-2.0",
  "peerDependencies": {
    "moment": "^2.27.0",
    "numeral": "^2.0.6"
  },
  "devDependencies": {
    "@types/jest": "^26.0.13",
    "@types/lodash": "^4.14.161",
    "@types/numeral": "0.0.29",
    "cross-env": "^7.0.3",
    "full-icu": "^1.3.1",
    "jest": "^26.4.2",
    "moment": "^2.27.0",
    "numeral": "^2.0.6",
    "reflect-metadata": "^0.1.13",
    "ts-jest": "^26.3.0",
    "ts-node": "^9.0.0",
    "tslint": "^6.1.3",
    "typescript": "^4.0.2"
  },
  "config": {
    "ca": {
      "rollupOptions": {
        "entryPoint": "public_api.ts",
        "tsconfig": "tsconfig.json",
        "externals": [],
        "targets": {
          "angular": false,
          "web": false,
          "node": true
        },
        "suppressCircularDependencyWarnings": true
      }
    }
  },
  "dependencies": {
    "lodash": "^4.17.20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codearchitects/CodeArchitects.EnterprisePlatform.WebStack.git"
  },
  "main": "dist/types/public_api.js",
  "typings": "dist/types/public_api.d.ts"
}
