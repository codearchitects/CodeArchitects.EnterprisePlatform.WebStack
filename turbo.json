{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "env": ["TZ"]
    },
    "typedoc": {
      "dependsOn": ["^build"],
      "outputs": ["typedocs/**"]
    },
    "clean.artifacts": {
      "cache": false
    }
  }
}
