{
  "name": "integration-tests",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "clean": "node ../../rimraf.js node_modules && npm run clean.self.package",
    "clean.self.package": "node ../../rimraf.js ../../dist/ca-webstack-ng-i18n-0.0.0.tgz",
    "setup": "cd ../../dist && npm pack && cd ../tests/integration && npm install --no-package-lock --no-optional --loglevel=error",
    "test": "npm run clean && npm run setup && ng test --watch=false && npm run clean.self.package",
    "e2e": "npm run clean && npm run setup && ng e2e && npm run clean.self.package"
  },
  "private": true,
  "peerDependencies": {
    "@angular/core": "~8.1.2",
    "@angular/platform-browser": "~8.1.2",
    "@angular/platform-browser-dynamic": "~8.1.2"
  },
  "dependencies": {
    "@ca-webstack/ng-i18n": "file:../../dist/ca-webstack-ng-i18n-0.0.0.tgz",
    "@angular/animations": "~8.1.2",
    "@angular/common": "~8.1.2",
    "@angular/compiler": "~8.1.2",
    "@angular/forms": "~8.1.2",
    "@angular/http": "^7.2.15",
    "@angular/router": "~8.1.2",
    "core-js": "^2.6.3",
    "rxjs": "^6.4.0",
    "zone.js": "~0.9.1"
  },
  "devDependencies": {
    "@angular/cli": "~8.1.2",
    "@angular/compiler-cli": "~8.1.2",
    "@angular/language-service": "~8.1.2",
    "@types/jasmine": "~3.3.8",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^10.12.21",
    "codelyzer": "^5.0.1",
    "jasmine-core": "~3.3.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "^4.0.0",
    "karma-chrome-launcher": "^2.2.0",
    "karma-cli": "~2.0.0",
    "karma-coverage-istanbul-reporter": "^2.0.4",
    "karma-jasmine": "^2.0.1",
    "karma-jasmine-html-reporter": "^1.4.0",
    "protractor": "^5.4.2",
    "ts-node": "^8.0.2",
    "typescript": "3.4.5"
  }
}
